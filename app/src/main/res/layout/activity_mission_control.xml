<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- FPV 串流畫面 -->
    <SurfaceView
        android:id="@+id/surfaceViewFpv"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- HUD Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no">

        <!-- 左上：電池 + GPS -->
        <LinearLayout
            android:id="@+id/hudTopLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#80000000"
            android:padding="10dp"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <TextView
                android:id="@+id/tvBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BAT  --"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvGps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPS  -- ····"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 右上：任務狀態 + MQTT -->
        <LinearLayout
            android:id="@+id/hudTopRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#80000000"
            android:padding="10dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvMissionState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="任務  待機"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvMqttState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚪ MQTT --"
                android:textColor="#FFFFFF"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- 左下：飛行高度 -->
        <TextView
            android:id="@+id/tvAltitude"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALT  -- m"
            android:textColor="#FFFFFF"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:background="#80000000"
            android:padding="10dp"
            android:layout_marginBottom="24dp"
            android:layout_marginStart="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- 右下：與 Home 距離 -->
        <TextView
            android:id="@+id/tvDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DST  -- m"
            android:textColor="#FFFFFF"
            android:fontFamily="monospace"
            android:textSize="14sp"
            android:background="#80000000"
            android:padding="10dp"
            android:layout_marginBottom="24dp"
            android:layout_marginEnd="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 中央底部：座標顯示 -->
        <TextView
            android:id="@+id/tvCoordinates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LAT --  LNG --"
            android:textColor="#CCFFFFFF"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:background="#80000000"
            android:padding="8dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toTopOf="@id/btnCancelMission"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 中央底部：取消任務按鈕（預設隱藏） -->
        <Button
            android:id="@+id/btnCancelMission"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="取消任務"
            android:textColor="#FFFFFF"
            android:backgroundTint="#CCFF3B30"
            android:visibility="gone"
            android:layout_marginBottom="24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
